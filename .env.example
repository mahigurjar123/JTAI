# ============================================================
# JTAI — Environment Variables
# Copy this file to .env and fill in your Firebase credentials
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=5000

# ── FIREBASE CLIENT (paste from Firebase Console → Project Settings → Your Apps) ──
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── FIREBASE ADMIN SDK (paste from Firebase Console → Project Settings → Service Accounts → Generate new private key) ──
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
